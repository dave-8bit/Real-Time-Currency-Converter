{
  "compilerOptions": {
    "target": "ES2020",               // modern Node
    "module": "CommonJS",             // Node expects CommonJS for Express
    "rootDir": "./src",               // source folder
    "outDir": "./dist",               // compiled output
    "esModuleInterop": true,          // allows import axios from 'axios'
    "strict": true,                   // strict type checking
    "skipLibCheck": true,             // ignore type conflicts in node_modules
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "sourceMap": true
  }
}